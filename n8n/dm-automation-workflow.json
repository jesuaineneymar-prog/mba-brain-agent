  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mba-dm-trigger",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Receber Pedidos do Painel",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "mba-brain-dm-trigger"
    },
    {
      "parameters": {
        "jsCode": "// Separar perfis por plataforma\nconst profiles = $input.first().json.profiles || [];\nconst message = $input.first().json.message || '';\nconst n8nSecret = $input.first().json.n8nSecret || '';\nconst webhookUrl = $input.first().json.webhookUrl || '';\n\n// Separar por plataforma\nconst igProfiles = profiles.filter(p => p.platform === 'instagram');\nconst fbProfiles = profiles.filter(p => p.platform === 'facebook');\nconst ttProfiles = profiles.filter(p => p.platform === 'tiktok');\n\n// Interleaved: IG > FB > TT\nconst ordered = [];\nconst maxLen = Math.max(igProfiles.length, fbProfiles.length, ttProfiles.length);\nfor (let i = 0; i < maxLen; i++) {\n  if (i < igProfiles.length) ordered.push(igProfiles[i]);\n  if (i < fbProfiles.length) ordered.push(fbProfiles[i]);\n  if (i < ttProfiles.length) ordered.push(ttProfiles[i]);\n}\n\nreturn ordered.map(p => ({\n  json: {\n    ...p,\n    message,\n    n8nSecret,\n    webhookUrl,\n    _index: ordered.indexOf(p)\n  }\n}));"
      },
      "id": "split-platforms",
      "name": "Separar por Plataforma (IG>FB>TT)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "amount": 3,
        "batchSize": 1
      },
      "id": "loop-items",
      "name": "Processar um a um",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [690, 300]
    },
