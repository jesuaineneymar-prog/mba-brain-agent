    {
      "parameters": {
        "jsCode": "// Registar resultado e notificar painel\nconst item = $input.first().json;\nconst profileId = item.id || '';\nconst username = item.username || '';\nconst platform = item.platform || '';\nconst webhookUrl = item.webhookUrl || '';\nconst n8nSecret = item.n8nSecret || '';\n\n// Assumir sucesso se chegou aqui\nconst result = {\n  action: 'dm_result',\n  profileId,\n  username,\n  platform,\n  dmSent: true,\n  deliveryMsg: 'DM enviado via n8n (' + platform + ')'\n};\n\nreturn [{ json: result }];"
      },
      "id": "register-result",
      "name": "Registar Resultado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3990, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.webhookUrl || 'https://SEU-DOMINIO.vercel.app/api/webhook' }}",
        "authentication": "genericCredentialType",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-secret",
              "value": "={{ $json.n8nSecret || 'mba-brain-n8n-2024' }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "notify-panel",
      "name": "Notificar Painel (Webhook)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4210, 300]
